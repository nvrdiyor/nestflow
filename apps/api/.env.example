# NestFlow API configuration — copy to .env and adjust.

# Server
PORT=8787
HOST=0.0.0.0

# Security — SET BOTH IN PRODUCTION.
# JWT_SECRET: any long random string (auto-generated into data/jwt-secret if unset).
#JWT_SECRET=change-me-to-a-long-random-string
# Admin credentials for /api/admin/login (defaults are for local development only).
#ADMIN_USERNAME=nvrdiyor
#ADMIN_PASSWORD=change-me-in-production

# Storage
#DATA_DIR=./data
#DB_FILE=./data/nestflow.db

# Frontend
# Directory of the built web app to serve (defaults to ../web/dist).
#WEB_DIST=
# Allowed CORS origin (default: allow all — fine when API serves the app itself).
#CORS_ORIGIN=https://your-domain.com

# Business
#STARTING_CREDITS=100
