# Copy to .env on your VPS, then: docker compose up -d --build

# REQUIRED — admin panel password (username defaults to nvrdiyor).
ADMIN_PASSWORD=change-me-to-a-strong-password
#ADMIN_USERNAME=nvrdiyor

# Recommended — long random string (else auto-generated inside the volume).
#JWT_SECRET=

# IP-only mode: app on port 80 (default). For HTTPS mode set:
#HTTP_PORT=127.0.0.1:8787
#DOMAIN=your-domain.com

#STARTING_CREDITS=100
