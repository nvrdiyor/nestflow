{
  "name": "nestflow",
  "version": "0.1.0",
  "private": true,
  "description": "NestFlow AI — intelligent nesting platform for CNC / laser / plotter cutting",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "web": "npm run dev -w @nestflow/web",
    "engine:test": "npm run test -w @nestflow/engine",
    "engine:demo": "npm run demo -w @nestflow/engine",
    "engine:bench": "npm run bench -w @nestflow/engine"
  },
  "license": "UNLICENSED"
}
